/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running full-size tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a full size pipeline test.

    Use as follows:
        nextflow run nf-core/drop -profile test_full,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Full test dataset to check pipeline function'

    // Input data for full size test
    // TODO nf-core: Specify the paths to your full test data ( on nf-core/test-datasets or directly in repositories, e.g. SRA)
    // TODO nf-core: Give any required params for the test so that command line flags are not needed
    input = params.pipelines_testdata_base_path + 'drop/data/full_test/1.0.0/samplesheet.tsv'
    gene_annotation = params.pipelines_testdata_base_path + 'drop/data/full_test/1.0.0/gene_annotation.yaml'
    ncbi_fasta = 's3://nf-core-awsmegatests/drop/refs/GCF_000001405.40_GRCh38.p14_genomic.fna'
    ncbi_fai = 's3://nf-core-awsmegatests/drop/refs/GCF_000001405.40_GRCh38.p14_genomic.fna.fai'
    ncbi_dict = 's3://nf-core-awsmegatests/drop/refs/GCF_000001405.40_GRCh38.p14_genomic.dict'

    // Genome references
    genome = 'R64-1-1'
}
