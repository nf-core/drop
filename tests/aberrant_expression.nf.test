nextflow_pipeline {

    name "Test Workflow main.nf"
    script "../main.nf"

    test("Aberrant Expression Workflow") {

        when {
            params {
                outdir = "${outputDir}"
                ae_run = true
                as_run = false
                mae_run = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    getAllFilesFromDir(params.outdir, relative:true, ignoreFile: 'tests/.nftignore')
                ).match() }
            )
        }

    }

}
