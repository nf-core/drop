nextflow_pipeline {

    name "Test Workflow main.nf"
    script "../main.nf"

    test("Aberrant Expression Workflow") {

        when {
            params {
                outdir = "${outputDir}"
                ae_skip = false
                as_skip = true
                mae_skip = true
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    getAllFilesFromDir(params.outdir, relative:true, ignoreFile: 'tests/.nftignore')
                ).match() }
            )
        }

    }

}
