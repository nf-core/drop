/*
========================================================================================
    Nextflow config file for running nf-test tests
========================================================================================
*/

// TODO nf-core: Specify any additional parameters here
// Or any resources requirements
params {
    modules_testdata_base_path   = 'https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/modules/data/'
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/drop/data/'
}

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners

profiles {
    ci {
        docker.runOptions = "--rm" // Remove the container after execution
    }
}
