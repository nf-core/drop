nextflow_pipeline {

    name "Test Workflow main.nf"
    script "../main.nf"

    test("Mono Allelic Expression Workflow") {

        // The container for MAEQC_DNARNADESEQ is too big for the CI tests, running it in stub mode with a smaller container
        options "-stub"
        config "./mae_small_container.config"

        when {
            params {
                outdir = "${outputDir}"
                ae_skip = true
                as_skip = true
                mae_skip = false
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    getAllFilesFromDir(params.outdir, relative:true, ignoreFile: 'tests/.nftignore')
                ).match() }
            )
        }

    }

}
