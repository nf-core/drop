nextflow_process {

    name "Test Process MAEQC_DESEQDNARNA"
    script "../main.nf"
    process "MAEQC_DESEQDNARNA"

    tag "modules"
    tag "modules_local"
    tag "maeqc_deseqdnarna"

    test("homo_sapiens - counts") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'HG00096' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/alleliccounts/HG00096.csv.gz', checkIfExists: true)
                ], [
                    [ id: 'HG00103' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/alleliccounts/HG00103.csv.gz', checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - counts - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'HG00096' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/alleliccounts/HG00096.csv.gz', checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
