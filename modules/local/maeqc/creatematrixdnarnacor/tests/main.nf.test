nextflow_process {

    name "Test Process MAEQC_CREATEMATRIXDNARNACOR"
    script "../main.nf"
    process "MAEQC_CREATEMATRIXDNARNACOR"

    tag "modules"
    tag "modules_local"
    tag "maeqc_creatematrixdnarnacor"

    test("homo_sapiens - ods fitted") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    [ file(params.pipelines_testdata_base_path + 'intermediates/maeqc/deseq/HG00096.Rds', checkIfExists: true) ],
                    [ file(params.pipelines_testdata_base_path + 'inputs/dna_vcf/demo_chr21_ncbi.vcf.gz', checkIfExists: true) ],
                    [ file(params.pipelines_testdata_base_path + 'inputs/dna_vcf/demo_chr21_ncbi.vcf.gz.tbi', checkIfExists: true) ],
                    file(params.pipelines_testdata_base_path + 'inputs/samplesheet.tsv', checkIfExists: true),
                    [ 'HG00096' ],
                    "mae"
                ])
                input[1] = [
                    [ id:'qc' ],
                    file(params.pipelines_testdata_base_path + 'inputs/qc_vcf_1000G.vcf.gz', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/qc_vcf_1000G.vcf.gz.tbi', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
