nextflow_process {

    name "Test Process MERGECOUNTS"
    script "../main.nf"
    process "MERGECOUNTS"

    tag "modules"
    tag "modules_local"
    tag "mergecounts"

    test("homo_sapiens - counts") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'merged' ],
                    [
                        file(params.pipelines_testdata_base_path + 'intermediates/countreads/HG00096.Rds', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'intermediates/countreads/HG00103.Rds', checkIfExists: true)
                    ]
                ])
                input[1] = [
                    [ id: 'genome' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/preprocessgeneannotation/genome.count_ranges.Rds')
                ]
                input[2] = [
                    [ id: 'input' ],
                    file(params.pipelines_testdata_base_path + 'inputs/samplesheet_small.tsv')
                ]
                input[3] = ["test1", "test2"]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - gtf - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'merged' ],
                    [
                        file(params.pipelines_testdata_base_path + 'intermediates/countreads/HG00096.Rds', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'intermediates/countreads/HG00103.Rds', checkIfExists: true)
                    ]
                ])
                input[1] = [
                    [ id: 'genome' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/preprocessgeneannotation/genome.count_ranges.Rds')
                ]
                input[2] = [
                    [ id: 'input' ],
                    file(params.pipelines_testdata_base_path + 'inputs/samplesheet_small.tsv')
                ]
                input[3] = ["test1", "test2"]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
