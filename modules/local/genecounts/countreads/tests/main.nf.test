nextflow_process {

    name "Test Process GENECOUNTS_COUNTREADS"
    script "../main.nf"
    process "GENECOUNTS_COUNTREADS"

    tag "modules"
    tag "modules_local"
    tag "preprocessgeneannotation"
    tag "genecounts/countreads"

    test("homo_sapiens - bam, bai, count_ranges") {

        when {
            process {
                """
                input[0] = [
                    [id: 'HG00096'],
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096.bam'),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096.bam.bai'),
                    "yes", // STRAND
                    "IntersectionStrict", // COUNT MODE
                    true, // PAIRED END
                    true, // COUNT OVERLAPS
                    file(params.pipelines_testdata_base_path + 'intermediates/preprocessgeneannotation/genome.count_ranges.Rds')
                ]
                input[1] = 2000000 // yield size
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - bam, bai, count_ranges - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [id: 'HG00096'],
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096.bam'),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096.bam.bai'),
                    "yes", // STRAND
                    "IntersectionStrict", // COUNT MODE
                    true, // PAIRED END
                    true, // COUNT OVERLAPS
                    file(params.pipelines_testdata_base_path + 'intermediates/preprocessgeneannotation/genome.count_ranges.Rds')
                ]
                input[1] = 2000000 // yield size
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
