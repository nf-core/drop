nextflow_process {

    name "Test Process SPLICECOUNTS_COLLECTCOUNTS"
    script "../main.nf"
    process "SPLICECOUNTS_COLLECTCOUNTS"

    tag "modules"
    tag "modules_local"
    tag "splicecounts/collectcounts"

    setup {
        run("UNTAR", alias: "FDS_UNTAR") {
            script "../../../../nf-core/untar/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [id:"savedObjects"],
                    file(params.pipelines_testdata_base_path + 'intermediates/countrna/nonsplitreadsmerge/savedObjects.tar.gz')
                ])
                """
            }
        }

        run("UNTAR", alias: "CACHE_UNTAR") {
            script "../../../../nf-core/untar/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [id:"cache"],
                    file(params.pipelines_testdata_base_path + 'intermediates/countrna/splitreadsmerge/cache.tar.gz')
                ])
                """
            }
        }
    }

    test("homo_sapiens - fds, cache - false") {

        when {
            process {
                """
                input[0] = FDS_UNTAR.out.untar
                .combine(CACHE_UNTAR.out.untar.map { it[1] })
                .map { meta, fds, cache ->
                    [
                        [id:'fraser'],
                        fds.resolve("raw-local-fraser"),
                        cache.resolve("raw-local-fraser/gRanges_splitCounts.rds"),
                        cache.resolve("raw-local-fraser/spliceSites_splitCounts.rds"),
                        "fraser"
                    ]
                }
                input[1] = "FRASER2"
                """
            }
        }

        then {
            def file_list = path(process.out.fdsobj[0][1]).list()
            assertAll (
                { assert process.success },
                { assert snapshot(
                    file_list.findAll { file(it.toString()).name != "fds-object.RDS"},
                    file_list.findAll { file(it.toString()).name == "fds-object.RDS"}.collect { file(it.toString()).name },
                    process.out.versions
                ).match() }
            )
        }
    }

    test("homo_sapiens - fds, cache - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = FDS_UNTAR.out.untar
                .combine(CACHE_UNTAR.out.untar.map { it[1] })
                .map { meta, fds, cache ->
                    [
                        [id:'fraser'],
                        fds.resolve("raw-local-fraser"),
                        cache.resolve("raw-local-fraser/gRanges_splitCounts.rds"),
                        cache.resolve("raw-local-fraser/spliceSites_splitCounts.rds"),
                        "fraser"
                    ]
                }
                input[1] = "FRASER2"
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
