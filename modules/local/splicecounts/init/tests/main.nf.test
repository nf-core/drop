nextflow_process {

    name "Test Process SPLICECOUNTS_INIT"
    script "../main.nf"
    process "SPLICECOUNTS_INIT"

    tag "modules"
    tag "modules_local"
    tag "splicecounts_init"

    test("homo_sapiens - col_data") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'fraser' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/definedatasetsfromanno/fraser.tsv', checkIfExists: true),
                    "fraser"
                ])
                input[1] = "FRASER"
                input[2] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - col_data - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'fraser' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/definedatasetsfromanno/fraser.tsv', checkIfExists: true),
                    "fraser"
                ])
                input[1] = "FRASER"
                input[2] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
