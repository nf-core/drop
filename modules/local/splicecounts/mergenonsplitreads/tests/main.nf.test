                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00106.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00111.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00116.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00126.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00132.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00149.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00150.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00176.h5")
                        ],
                        [
                            file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00106.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00111.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00116.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00126.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00132.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00149.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00150.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00176.bam', checkIfExists: true)
                        ],
                        [
                            file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00106.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00111.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00116.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00126.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00132.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00149.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00150.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00176.bam.bai', checkIfExists: true)
                        ],
                        "fraser"
                    ]
                }
                input[1] = false
                input[2] = true
                input[3] = "FRASER2"
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - fds, cache - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [id: 'fraser']
                ])
                .combine(FDS_UNTAR.out.untar.map { it[1] })
                .combine(ORIGINAL_CACHE_UNTAR.out.untar.map { it[1] })
                .combine(NSPR_CACHE_UNTAR.out.untar.map { it[1] })
                .map { meta, fds, cache, nsp ->
                    [
                        meta,
                        fds.resolve("raw-local-fraser"),
                        cache.resolve("raw-local-fraser/gRanges_NonSplitCounts.rds"),
                        [
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00096.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00103.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00106.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00111.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00116.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00126.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00132.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00149.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00150.h5"),
                            nsp.resolve("nonSplicedCounts/raw-local-fraser/nonSplicedCounts-HG00176.h5")
                        ],
                        [
                            file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00106.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00111.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00116.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00126.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00132.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00149.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00150.bam', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00176.bam', checkIfExists: true)
                        ],
                        [
                            file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00106.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00111.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00116.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00126.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00132.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00149.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00150.bam.bai', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + 'inputs/HG00176.bam.bai', checkIfExists: true)
                        ],
                        "fraser"
                    ]
                }
                input[1] = false
                input[2] = false
                input[3] = "FRASER2"
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
