nextflow_process {

    name "Test Process COUNTRNA_SPLITREADSSAMPLEWISE"
    script "../main.nf"
    process "COUNTRNA_SPLITREADSSAMPLEWISE"

    tag "modules"
    tag "modules_local"
    tag "countrna/splitreadssamplewise"

    test("homo_sapiens - fds - false") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'HG00096' ],
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam.bai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/countrna/init/fds-object.RDS', checkIfExists: true),
                    'fraser',
                    'HG00096'
                ],
                [
                    [ id: 'HG00103' ],
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam.bai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/countrna/init/fds-object.RDS', checkIfExists: true),
                    'fraser',
                    'HG00103'
                ])
                input[1] = false
                input[2] = false
                input[3] = 'hg19'
                input[4] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - fds - true") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'HG00096' ],
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam.bai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/countrna/init/fds-object.RDS', checkIfExists: true),
                    'fraser',
                    'HG00096'
                ],
                [
                    [ id: 'HG00103' ],
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam.bai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/countrna/init/fds-object.RDS', checkIfExists: true),
                    'fraser',
                    'HG00103'
                ])
                input[1] = false
                input[2] = false
                input[3] = 'hg19'
                input[4] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - fds - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'HG00096' ],
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam.bai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/countrna/init/fds-object.RDS', checkIfExists: true),
                    'fraser',
                    'HG00096'
                ],
                [
                    [ id: 'HG00103' ],
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam.bai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/countrna/init/fds-object.RDS', checkIfExists: true),
                    'fraser',
                    'HG00103'
                ])
                input[1] = false
                input[2] = false
                input[3] = 'hg19'
                input[4] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
