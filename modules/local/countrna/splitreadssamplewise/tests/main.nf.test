nextflow_process {

    name "Test Process COUNTRNA_SPLITREADSSAMPLEWISE"
    script "../main.nf"
    process "COUNTRNA_SPLITREADSSAMPLEWISE"

    tag "modules"
    tag "modules_local"
    tag "countrna/splitreadssamplewise"

    setup {
        run("UNTAR") {
            script "../../../../nf-core/untar/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [id:"savedObjects"],
                    file(params.pipelines_testdata_base_path + 'intermediates/countrna/init/savedObjects.tar.gz')
                ])
                """
            }
        }
    }

    test("homo_sapiens - fds - false") {

        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { _meta, fds -> [
                    [ id: 'HG00096' ],
                    fds,
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam.bai', checkIfExists: true),
                    'fraser',
                    'HG00096'
                ]}
                input[1] = false
                input[2] = false
                input[3] = 'hg19'
                input[4] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - fds - true") {

        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { _meta, fds -> [
                    [ id: 'HG00096' ],
                    fds,
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam.bai', checkIfExists: true),
                    'fraser',
                    'HG00096'
                ]}
                input[1] = true
                input[2] = true
                input[3] = 'hg19'
                input[4] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - fds - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { _meta, fds -> [
                    [ id: 'HG00096' ],
                    fds,
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096_ncbi.bam.bai', checkIfExists: true),
                    'fraser',
                    'HG00096'
                ]}
                input[1] = false
                input[2] = false
                input[3] = 'hg19'
                input[4] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
