nextflow_process {

    name "Test Process FRASER_FITHYPERPARAMS"
    script "../main.nf"
    process "FRASER_FITHYPERPARAMS"

    tag "modules"
    tag "modules_local"
    tag "fraser/fithyperparams"

    setup {
        run("UNTAR") {
            script "../../../../nf-core/untar/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [id:"savedObjects"],
                    file(params.pipelines_testdata_base_path + 'intermediates/fraser/filterexpression/savedObjects.tar.gz')
                ])
                """
            }
        }
    }

    test("homo_sapiens - fds - false") {
        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds.resolve("fraser"), "fraser" ]
                }
                input[1] = false
                input[2] = "PCA"
                input[3] = 6
                input[4] = false
                input[5] = "FRASER2"
                input[6] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            def file_list = path(process.out.fdsobj[0][1]).list()
            assertAll (
                { assert process.success },
                { assert snapshot(
                    file_list.findAll { file(it.toString()).name != "fds-object.RDS"},
                    file_list.findAll { file(it.toString()).name == "fds-object.RDS"}.collect { file(it.toString()).name },
                    process.out.versions
                ).match() }
            )
        }
    }

    test("homo_sapiens - fds - true") {
        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds.resolve("fraser"), "fraser" ]
                }
                input[1] = true
                input[2] = "PCA"
                input[3] = 6
                input[4] = false
                input[5] = "FRASER2"
                input[6] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            def file_list = path(process.out.fdsobj[0][1]).list()
            assertAll (
                { assert process.success },
                { assert snapshot(
                    file_list.findAll { file(it.toString()).name != "fds-object.RDS"},
                    file_list.findAll { file(it.toString()).name == "fds-object.RDS"}.collect { file(it.toString()).name },
                    process.out.versions
                ).match() }
            )
        }
    }

    test("homo_sapiens - fds - int") {
        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds.resolve("fraser"), "fraser" ]
                }
                input[1] = 22
                input[2] = "PCA"
                input[3] = 6
                input[4] = "FRASER"
                input[5] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            def file_list = path(process.out.fdsobj[0][1]).list()
            assertAll (
                { assert process.success },
                { assert snapshot(
                    file_list.findAll { file(it.toString()).name != "fds-object.RDS"},
                    file_list.findAll { file(it.toString()).name == "fds-object.RDS"}.collect { file(it.toString()).name },
                    process.out.versions
                ).match() }
            )
        }
    }

    test("homo_sapiens - fds - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds.resolve("fraser"), "fraser" ]
                }
                input[1] = false
                input[2] = "PCA"
                input[3] = 6
                input[4] = "FRASER"
                input[5] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
