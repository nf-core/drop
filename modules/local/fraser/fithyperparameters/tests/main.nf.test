nextflow_process {

    name "Test Process FRASER_FITHYPERPARAMETERS"
    script "../main.nf"
    process "FRASER_FITHYPERPARAMETERS"

    tag "modules"
    tag "modules_local"
    tag "fraser/fithyperparameters"

    setup {
        run("UNTAR") {
            script "../../../../nf-core/untar/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [id:"savedObjects"],
                    file(params.pipelines_testdata_base_path + 'intermediates/fraser/filterexpression/savedObjects.tar.gz')
                ])
                """
            }
        }
    }

    test("homo_sapiens - fds - false") {
        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds, "fraser" ]
                }
                input[1] = false
                input[2] = "PCA"
                input[3] = 6
                input[4] = "FRASER"
                input[5] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - fds - true") {
        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds, "fraser" ]
                }
                input[1] = true
                input[2] = "PCA"
                input[3] = 6
                input[4] = "FRASER"
                input[5] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - fds - int") {
        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds, "fraser" ]
                }
                input[1] = 22
                input[2] = "PCA"
                input[3] = 6
                input[4] = "FRASER"
                input[5] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - fds - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds, "fraser" ]
                }
                input[1] = false
                input[2] = "PCA"
                input[3] = 6
                input[4] = "FRASER"
                input[5] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
