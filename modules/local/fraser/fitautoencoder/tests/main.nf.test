nextflow_process {

    name "Test Process FRASER_FITAUTOENCODER"
    script "../main.nf"
    process "FRASER_FITAUTOENCODER"

    tag "modules"
    tag "modules_local"
    tag "fraser/fitautoencoder"

    setup {
        run("UNTAR") {
            script "../../../../nf-core/untar/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [id:"savedObjects"],
                    file(params.pipelines_testdata_base_path + 'intermediates/fraser/fithyperparameters/savedObjects.tar.gz')
                ])
                """
            }
        }
    }

    test("homo_sapiens - fds - fraser") {
        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds, "fraser" ]
                }
                input[1] = "PCA"
                input[2] = "FRASER"
                input[3] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            def file_list = path(process.out.fdsobj[0][1]).list()[0].list()
            assertAll (
                { assert process.success },
                { assert snapshot(
                    file_list.findAll { file(it.toString()).name != "fds-object.RDS" && !file(it.toString()).name.startsWith("predictedMeans_")},
                    file_list.findAll { file(it.toString()).name == "fds-object.RDS" || file(it.toString()).name.startsWith("predictedMeans_")}.collect { file(it.toString()).name },
                    process.out.versions
                ).match() }
            )
        }
    }

    test("homo_sapiens - fds - fraser2") {
        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds, "fraser" ]
                }
                input[1] = "PCA"
                input[2] = "FRASER2"
                input[3] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            def file_list = path(process.out.fdsobj[0][1]).list()[0].list()
            assertAll (
                { assert process.success },
                { assert snapshot(
                    file_list.findAll { file(it.toString()).name != "fds-object.RDS" && !file(it.toString()).name.startsWith("predictedMeans_")},
                    file_list.findAll { file(it.toString()).name == "fds-object.RDS" || file(it.toString()).name.startsWith("predictedMeans_")}.collect { file(it.toString()).name },
                    process.out.versions
                ).match() }
            )
        }
    }

    test("homo_sapiens - fds - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = UNTAR.out.untar.map { meta, fds ->
                    [ [id:'fraser'], fds, "fraser" ]
                }
                input[1] = "PCA"
                input[2] = "FRASER"
                input[3] = file("${projectDir}/assets/helpers/aberrant_splicing_config.R")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
