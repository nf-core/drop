nextflow_process {

    name "Test Process OUTRIDER_RUN"
    script "../main.nf"
    process "OUTRIDER_RUN"

    tag "modules"
    tag "modules_local"
    tag "OUTRIDER_RUN"

    test("drop demo - ods_unfitted.Rds") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    [ file('/data/nasif12/home_if12/wayu0/nf-core-drop/tests/data/aberrantExpression/ods_unfitted.Rds', checkIfExists: true) ]
                ])
                input[1] = 'autoencoder'
                input[2] = 3
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.ods_fitted.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.versions
                ).match() }
            )
        }
    }
        test("homo_sapiens - gtf - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    [ file('/data/nasif12/home_if12/wayu0/nf-core-drop/tests/data/aberrantExpression/ods_unfitted.Rds', checkIfExists: true) ]
                ])
                input[1] = 'autoencoder'
                input[2] = 3
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
