nextflow_process {

    name "Test Process OUTRIDER_RESULTS"
    script "../main.nf"
    process "OUTRIDER_RESULTS"

    tag "modules"
    tag "modules_local"
    tag "outrider_results"

    test("homo_sapiens - ods") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/pvalsoutrider/ods_pvals.Rds', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/preprocessgeneannotation/genome.gene_name_mapping.tsv', checkIfExists: true)
                ])
                input[1] = [
                    [ id: 'samplesheet' ],
                    file(params.pipelines_testdata_base_path + 'inputs/samplesheet.tsv', checkIfExists: true)
                ]
                input[2] = [
                    [ id: 'hpo' ],
                    file(params.pipelines_testdata_base_path + 'genome/hpo_genes.tsv.gz', checkIfExists: true)
                ]
                input[3] = 0.05
                input[4] = 0
                input[5] = file("${projectDir}/assets/helpers/add_HPO_cols.R", checkIfExists: true)
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - ods - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/pvalsoutrider/ods_pvals.Rds', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/preprocessgeneannotation/genome.gene_name_mapping.tsv', checkIfExists: true)
                ])
                input[1] = [
                    [ id: 'samplesheet' ],
                    file(params.pipelines_testdata_base_path + 'inputs/samplesheet.tsv', checkIfExists: true)
                ]
                input[2] = [
                    [ id: 'hpo' ],
                    file(params.pipelines_testdata_base_path + 'genome/hpo_genes.tsv.gz', checkIfExists: true)
                ]
                input[3] = 0.05
                input[4] = 0
                input[5] = file("${projectDir}/assets/helpers/add_HPO_cols.R", checkIfExists: true)
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
