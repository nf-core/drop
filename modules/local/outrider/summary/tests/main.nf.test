nextflow_process {

    name "Test Process OUTRIDER_SUMMARY"
    script "../main.nf"
    process "OUTRIDER_SUMMARY"

    tag "modules"
    tag "modules_local"
    tag "OUTRIDER_SUMMARY"

    test("drop demo - ods.Rds") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    [ file(params.pipelines_testdata_base_path + 'intermediates/pvalsoutrider/ods_pvals.Rds', checkIfExists: true) ]
                ])
                input[1] = Channel.of([
                    [ id: 'test' ],
                    [ file(params.pipelines_testdata_base_path + 'intermediates/resultsourtider/OUTRIDER_results.tsv', checkIfExists: true) ]
                ])
                input[2] = 1
                input[3] = 0
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.sample_mqc.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.encoding_mqc.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.genes_mqc.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.batch_mqc_1.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.batch_mqc_2.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.heatmap_mqc_1.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.heatmap_mqc_2.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.bcv_mqc.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.result_mqc_1.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.result_mqc_2.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.result_mqc_3.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.result.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.versions
                ).match() }
            )
        }
    }
        test("homo_sapiens - gtf - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    [ file(params.pipelines_testdata_base_path + 'intermediates/pvalsoutrider/ods_pvals.Rds', checkIfExists: true) ]
                ])
                input[1] = Channel.of([
                    [ id: 'test' ],
                    [ file(params.pipelines_testdata_base_path + 'intermediates/resultsourtider/OUTRIDER_results.tsv', checkIfExists: true) ]
                ])
                input[2] = 1
                input[3] = 0
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
