nextflow_process {

    name "Test Process OUTRIDER_SUMMARY"
    script "../main.nf"
    process "OUTRIDER_SUMMARY"

    tag "modules"
    tag "modules_local"
    tag "OUTRIDER_SUMMARY"

    test("drop demo - ods.Rds") {

        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/pvalsoutrider/ods_pvals.Rds', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/resultsourtider/OUTRIDER_results.tsv', checkIfExists: true),
                    "outrider",
                    "v29"
                ]
                input[1] = 1
                input[2] = 0
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.outrider_overview.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.encoding_dimension.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.aberrant_genes_per_sample.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.batch_correction_raw.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.batch_correction_normalized.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.geneSampleHeatmap_raw.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.geneSampleHeatmap_normalized.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.bcv.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.outrider_result_overview.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.aberrant_samples.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.significant_results.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.result.collect { meta, r -> [ meta, file(r).name ] },
                    process.out.versions
                ).match() }
            )
        }
    }
        test("homo_sapiens - gtf - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/pvalsoutrider/ods_pvals.Rds', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/resultsourtider/OUTRIDER_results.tsv', checkIfExists: true),
                    "outrider",
                    "v29"
                ]
                input[1] = 1
                input[2] = 0
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
