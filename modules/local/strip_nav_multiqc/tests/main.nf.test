nextflow_process {

    name "Test Process STRIP_NAV_MULTIQC"
    script "../main.nf"
    process "STRIP_NAV_MULTIQC"

    tag "modules"
    tag "modules_local"
    tag "STRIP_NAV_MULTIQC"

    test("mulitqc report ") {

        when {
            process {
                """
                input[0] = [ file(params.pipelines_testdata_base_path + 'multiqc_report_v1.29.html', checkIfExists: true) ]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
        test("mulitqc report- stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [ file(params.pipelines_testdata_base_path + 'multiqc_report_v1.29.html', checkIfExists: true) ]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
