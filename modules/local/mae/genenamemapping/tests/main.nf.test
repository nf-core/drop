nextflow_process {

    name "Test Process MAE_GENENAMEMAPPING"
    script "../main.nf"
    process "MAE_GENENAMEMAPPING"

    tag "modules"
    tag "modules_local"
    tag "mae_genenamemapping"

    test("homo_sapiens - gtf") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'v29' ],
                    file(params.pipelines_testdata_base_path + 'genome/gencode_annotation_trunc.gtf', checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - gtf - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'v29' ],
                    file(params.pipelines_testdata_base_path + 'genome/gencode_annotation_trunc.gtf', checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
