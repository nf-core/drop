nextflow_process {

    name "Test Process MAE_ALLELICCOUNTS"
    script "../main.nf"
    process "MAE_ALLELICCOUNTS"

    tag "modules"
    tag "modules_local"
    tag "mae_alleliccounts"

    test("homo_sapiens - vcf, bam - ucsc") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'HG00096' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/createsnvs/HG00096.vcf.gz', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/createsnvs/HG00096.vcf.gz.tbi', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096.bam.bai', checkIfExists: true),
                    "HG00096",
                    file(params.pipelines_testdata_base_path + 'genome/chr21.fa', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'genome/chr21.fa.fai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'genome/chr21.dict', checkIfExists: true)
                ],
                [
                    [ id: 'HG00103' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/createsnvs/HG00103.vcf.gz', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/createsnvs/HG00103.vcf.gz.tbi', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam.bai', checkIfExists: true),
                    "HG00103",
                    file(params.pipelines_testdata_base_path + 'genome/chr21.fa', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'genome/chr21.fa.fai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'genome/chr21.dict', checkIfExists: true)
                ])
                input[1] = true
                input[2] = file("${projectDir}/assets/chr_NCBI_UCSC.txt")
                input[3] = file("${projectDir}/assets/chr_UCSC_NCBI.txt")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - vcf, bam - ucsc - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'HG00096' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/createsnvs/HG00096.vcf.gz', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/createsnvs/HG00096.vcf.gz.tbi', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00096.bam.bai', checkIfExists: true),
                    "HG00096",
                    file(params.pipelines_testdata_base_path + 'genome/chr21.fa', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'genome/chr21.fa.fai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'genome/chr21.dict', checkIfExists: true)
                ],
                [
                    [ id: 'HG00103' ],
                    file(params.pipelines_testdata_base_path + 'intermediates/createsnvs/HG00103.vcf.gz', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'intermediates/createsnvs/HG00103.vcf.gz.tbi', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'inputs/HG00103.bam.bai', checkIfExists: true),
                    "HG00103",
                    file(params.pipelines_testdata_base_path + 'genome/chr21.fa', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'genome/chr21.fa.fai', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'genome/chr21.dict', checkIfExists: true)
                ])
                input[1] = true
                input[2] = file("${projectDir}/assets/chr_NCBI_UCSC.txt")
                input[3] = file("${projectDir}/assets/chr_UCSC_NCBI.txt")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
