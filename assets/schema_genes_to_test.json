{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/drop/master/assets/schema_input.json",
    "title": "nf-core/drop pipeline - params.gene_annotation schema",
    "description": "Schema for the file provided with params.gene_annotation",
    "type": "object",
    "properties": {
        "Test_subset": {
            "type": "array",
            "items": {
                "type": "array",
                "items": {
                    "type": "string"
                }
            }
        },
        "Sample_specific_genes": {
            "type": "object",
            "patternProperties": {
                "^\\S+$": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
